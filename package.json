{
  "name": "@tekmidian/telex",
  "version": "0.2.5",
  "description": "Telegram MCP bridge for Claude Code — bidirectional self-chat via MTProto",
  "type": "module",
  "bin": {
    "telex": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/index.ts",
